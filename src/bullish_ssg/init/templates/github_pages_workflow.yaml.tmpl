name: Bullish SSG CI

on:
  pull_request:
  push:
    branches: [main]

jobs:
  validate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: cachix/install-nix-action@v27
      - name: Run validation
        run: {validate_command}
      - name: Dry-run build
        run: {build_dry_run_command}
      - name: Dry-run deploy
        run: {deploy_dry_run_command}
